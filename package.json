{
  "name": "habitforge2",
  "version": "1.0.0",
  "description": "HabitForge GCSE — offline-first study dashboard",
  "main": "electron/main.js",
  "scripts": {
    "web:dev": "vite --port 3000 --strictPort",
    "desktop:dev": "concurrently -k \"npm run web:dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_RENDERER_URL=http://localhost:3000 electron .\"",
    "desktop:build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umar1234921/Habitforge2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/umar1234921/Habitforge2/issues"
  },
  "homepage": "https://github.com/umar1234921/Habitforge2#readme",
  "devDependencies": {
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "29.1.0",
    "electron-builder": "24.13.3",
    "vite": "5.4.19",
    "wait-on": "8.0.3"
  },
  "build": {
    "appId": "com.habitforge.gcse",
    "productName": "HabitForge GCSE",
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!out/**/*",
      "!release/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
